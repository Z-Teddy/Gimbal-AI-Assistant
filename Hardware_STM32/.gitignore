# ==============================================================================
# 1. 编辑器与 IDE 缓存 (VS Code / Local History)
# ==============================================================================
.history/
.vscode/

# ==============================================================================
# 2. Keil MDK-ARM 编译输出目录
# ==============================================================================
Output/
Listing/
Listings/
Objects/
DebugConfig/
RTE/

# ==============================================================================
# 3. Keil 工程配置与中间文件 (用户特定配置，不应上传)
# ==============================================================================
*.uvoptx                # 用户调试配置 (断点、窗口布局等本地信息)
*.uvguix.* # GUI 界面布局文件 (本地配置)
*.bak                   # 自动备份文件
*.dep                   # 编译依赖文件
*.scvd                  # 组件视图描述文件
*.iex                   # 加密源文件
JLinkLog.txt            # J-Link 调试日志

# ==============================================================================
# 4. 编译产生的二进制与临时文件 (Build Artifacts)
# ==============================================================================
*.map                   # 链接映射文件 (Map file)
*.o                     # 编译目标文件 (Object file)
*.d                     # 依赖描述文件 (Dependency)
*.crf                   # 交叉引用文件 (Cross-Reference)
*.lnp                   # 链接器输入文件
*.axf                   # 可执行映像文件 (固件ELF，通常不上传源工程)
*.htm                   # 编译报告文件
*.build_log.htm         # 构建日志

# ==============================================================================
# 5. 操作系统生成文件
# ==============================================================================
Thumbs.db
Desktop.ini